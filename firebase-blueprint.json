  "firestore": {
    "settings/site": {
      "schema": "SiteSettings",
      "description": "Site global Settings"
    },
    "products/{productId}": {
      "schema": "Product",
      "description": "Scent perfumes product items"
    },
    "reviews/{reviewId}": {
