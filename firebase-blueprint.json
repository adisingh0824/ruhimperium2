      "description": "Scent product ratings and reviews"
    },
    "orders/{orderId}": {
      "schema": "Order",
      "description": "Customer purchase invoice orders list"
    },
    "coupons/{couponId}": {
      "schema": "Coupon",
      "description": "Discount token coupons"
    },
    "blogArticles/{articleId}": {
      "schema": "BlogArticle",
      "description": "Fragrance travelogue blog posts"
